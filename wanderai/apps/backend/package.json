{
  "name": "@wanderai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build --workspace @wanderai/shared && tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prisma:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^1.14.1",
    "@prisma/client": "^5.19.1",
    "@wanderai/shared": "1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "openai": "^4.58.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.16.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0"
  }
}
